# Example environment variables for Telegram Subscription Bot
# Copy this file to .env and fill in your actual values

# Telegram Bot Token (get from BotFather)
BOT_TOKEN=your-telegram-bot-token-here

# Telegram User ID of the bot owner (integer)
BOT_OWNER_ID=123456789

# Solana wallet address for receiving payments
SOLANA_WALLET_ADDRESS=your-solana-wallet-address-here

# Solana RPC URL (e.g., from Triton, QuickNode, or your own node)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Subscription pricing by plan (format: weeks:amount, comma-separated, e.g. 1:200,3:500)
# IMPORTANT: a value of '200' means $200 worth of SOL
SUBSCRIBE_AMOUNT_BY_PLANS=1:200

# Subscription duration (days per payment)
NUMBER_DAYS_FROM_ONE_PAYMENT=7

# Days before expiry to notify users (comma-separated)
SUBSCRIBE_END_NOTIFICATION_DAYS=3,1

# List of admin Telegram user IDs (comma-separated)
ADMINS_ID_LIST=

# Mailing text sent to users (supports HTML formatting)
MAILING_TEXT=Hello

# Enable payment amount deviation (true/false)
# If enabled, allows a small deviation in the payment amount (in SOL). Disabled by default for strict payment validation.
AMOUNT_DEVIATION_ENABLED=false

# Allowed payment deviation value in SOL (float)
AMOUNT_DEVIATION_VALUE=0.01